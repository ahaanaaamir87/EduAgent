# --- EduAgent Configuration ---

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# Performance tuning (lower these on CPU-only machines for faster replies)
OLLAMA_MAX_TOKENS=350
OLLAMA_NUM_CTX=2048

# App secret (change this in production!)
SECRET_KEY=change-this-to-a-long-random-string

# Database
DATABASE_URL=sqlite:///./data/db/eduagent.db

# RAG
CHROMA_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RAG_TOP_K=4

# Agent mode: "local" (Ollama, default) or "adk" (Google ADK + Gemini, needs GOOGLE_API_KEY)
AGENT_BACKEND=local
GOOGLE_API_KEY=

# Google OAuth (for "Continue with Google")
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
